# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Gemini (https://aistudio.google.com — primary model)
GEMINI_API_KEY=

# Anthropic (https://console.anthropic.com — fallback)
ANTHROPIC_API_KEY=

# App
PORT=3000

# LLM Model Config (optional — defaults in src/model-config.js)
# Provider auto-detected from prefix: gemini-* → Gemini, claude-* → Anthropic
# PULSE_MODEL_BRAIN=gemini-2.5-flash-lite       # Agent brain (tool calling)
# PULSE_MODEL_COMPOSE=gemini-2.5-flash-lite      # SMS composition
# PULSE_MODEL_EXTRACT=gemini-2.5-flash            # Event extraction (scrape-time)
# PULSE_MODEL_DETAILS=gemini-2.5-flash             # Event detail composition
# PULSE_MODEL_FALLBACK=claude-haiku-4-5-20251001   # Fallback for all roles

# Ticketmaster (https://developer.ticketmaster.com — 5,000 req/day free)
TICKETMASTER_API_KEY=

# Alerts (https://resend.com — free tier: 100 emails/day)
RESEND_API_KEY=
ALERT_EMAIL=jkoufopoulos@gmail.com

# Card pages (branded /e/{eventId} URLs; off by default, uses direct source URLs)
# PULSE_CARD_ENABLED=true

# Link previews (sends each pick's URL as separate SMS for iMessage rich previews)
# PULSE_LINK_PREVIEWS=true

# Gmail API (for Yutori email ingestion — optional, falls back to file-based)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
